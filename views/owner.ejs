<!DOCTYPE html>
<html lang="ru"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Owner Panel -- QWA</title>
  <link rel="stylesheet" href="/style.css">
</head><body>

<div class="topbar">
  <div class="topbar-left"><a href="/" class="topbar-logo">QWA</a></div>
  <div class="topbar-right">
    <a href="/owner" class="top-btn top-btn-red">Owner Panel</a>
    <a href="/admin" class="top-btn top-btn-dark">Админка</a>
    <a href="/profile" class="top-btn top-btn-outline"><%= currentUser.username %></a>
    <a href="/logout" class="top-btn top-btn-ghost">Выйти</a>
  </div>
</div>

<div class="container">
  <div class="section-box">
    <div class="section-header" style="background:#CC0000;">OWNER PANEL -- <%= currentUser.username %></div>
    <div style="padding:15px;">

      <div class="stats-bar">
        <div class="stat-item">Юзеров: <span class="stat-num"><%= stats.total_users %></span></div>
        <div class="stat-item">Тем: <span class="stat-num"><%= stats.total_threads %></span></div>
        <div class="stat-item">Постов: <span class="stat-num"><%= stats.total_posts %></span></div>
      </div>

      <!-- Протокол Пекорин -->
      <div class="section-box">
        <div class="section-header" style="background:#000;">ПРОТОКОЛ "ПЕКОРИН"</div>
        <div style="padding:15px;background:#1a1a1a;">

          <p style="color:#888;margin-bottom:10px;font-size:12px;">
            Статус форума:
            <% if(forumDisabled) { %>
              <span style="background:#CC0000;color:#fff;padding:2px 8px;font-size:11px;font-weight:bold;">ОТКЛЮЧЁН</span>
            <% } else { %>
              <span style="background:#006600;color:#fff;padding:2px 8px;font-size:11px;font-weight:bold;">РАБОТАЕТ</span>
            <% } %>
          </p>

          <% if(!forumDisabled) { %>
            <form method="POST" action="/owner/toggle-forum" onsubmit="return confirm('ОТКЛЮЧИТЬ ФОРУМ?')">
              <input type="hidden" name="action" value="disable">
              <p style="color:#888;font-size:11px;margin-bottom:6px;">Введите пароль:</p>
              <input type="password" name="password" required style="padding:4px 8px;border:1px solid #555;background:#222;color:#fff;font-size:13px;font-family:monospace;width:200px;">
              <button type="submit" style="background:#CC0000;color:#fff;border:none;padding:6px 15px;font-size:12px;font-weight:bold;cursor:pointer;margin-left:6px;">ОТКЛЮЧИТЬ</button>
            </form>
          <% } else { %>
            <form method="POST" action="/owner/toggle-forum">
              <input type="hidden" name="action" value="enable">
              <p style="color:#888;font-size:11px;margin-bottom:6px;">Введите пароль:</p>
              <input type="password" name="password" required style="padding:4px 8px;border:1px solid #555;background:#222;color:#fff;font-size:13px;font-family:monospace;width:200px;">
              <button type="submit" style="background:#006600;color:#fff;border:none;padding:6px 15px;font-size:12px;font-weight:bold;cursor:pointer;margin-left:6px;">ВКЛЮЧИТЬ</button>
            </form>
          <% } %>

        </div>
      </div>

    </div>
  </div>
</div>

<div class="footer">QWA Forum | Owner Panel</div>
</body></html>