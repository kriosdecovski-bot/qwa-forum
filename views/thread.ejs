<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= thread.subject || 'Thread #' + thread.id %> -- /<%= board.slug %>/ -- QWA</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/">Glavnaya</a>
    <% boards.forEach(function(b) { %>
      <a href="/<%= b.slug %>/"<% if(b.slug===board.slug){ %> class="active"<% } %>>/<%= b.slug %>/</a>
    <% }); %>
  </div>
  <div class="topbar-right">QWA Forum</div>
</div>

<div class="breadcrumbs">
  <a href="/">QWA</a>
  <span>></span>
  <a href="/<%= board.slug %>/">/<%= board.slug %>/ -- <%= board.name %></a>
  <span>></span>
  <strong><%= thread.subject || 'Thread #' + thread.id %></strong>
</div>

<div class="container">

  <!-- REPLY FORM -->
  <div class="form-section">
    <div class="section-header">Otvetit v temu</div>
    <div class="form-body visible">
      <% if (thread.is_locked) { %>
        <div style="padding:15px;color:#888;text-align:center;">Tema zakryta. Otvety otklyucheny.</div>
      <% } else { %>
      <form action="/<%= board.slug %>/thread/<%= thread.id %>/reply" method="POST">
        <div class="form-row">
          <div class="form-label">Imya</div>
          <div class="form-input">
            <input type="text" name="name" placeholder="Anonymous" maxlength="50">
          </div>
        </div>
        <div class="form-row">
          <div class="form-label">Soobshenie</div>
          <div class="form-input">
            <textarea name="message" placeholder="Vash otvet..." maxlength="5000" required></textarea>
            <div class="form-hint">&gt;greentext &gt;&gt;123 ssylka na post. "sage" v imeni = ne podnimat temu.</div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-label"></div>
          <div class="form-input">
            <button type="submit" class="form-submit">Otpravit otvet</button>
          </div>
        </div>
      </form>
      <% } %>
    </div>
  </div>

  <!-- OP POST -->
  <div class="post op-post" id="p<%= thread.id %>">
    <div class="post-head">
      <div class="post-head-left">
        <% if (thread.subject) { %><span class="post-subject"><%= thread.subject %></span><% } %>
        <span class="post-author"><%= thread.author %></span>
        <span class="post-date"><%= formatDate(thread.created_at) %></span>
        <% if (thread.is_pinned) { %><span class="pinned-tag">PIN</span><% } %>
        <% if (thread.is_locked) { %><span class="locked-tag">LOCK</span><% } %>
      </div>
      <div class="post-num">No.<%= thread.id %></div>
    </div>
    <div class="post-body"><%- formatPost(thread.message) %></div>
  </div>

  <!-- REPLIES -->
  <% if (posts.length > 0) { %>
    <% posts.forEach(function(p) { %>
    <div class="post reply-post" id="p<%= p.id %>">
      <div class="post-head">
        <div class="post-head-left">
          <span class="post-author"><%= p.author %></span>
          <span class="post-date"><%= formatDate(p.created_at) %></span>
        </div>
        <div class="post-num"><a href="#p<%= p.id %>">No.<%= p.id %></a></div>
      </div>
      <div class="post-body"><%- formatPost(p.message) %></div>
    </div>
    <% }); %>
  <% } else { %>
    <div class="empty-state">
      Otvetov poka net. Budte pervym!
    </div>
  <% } %>

  <div class="reply-count-info">
    Vsego otvetov: <%= posts.length %>
  </div>

  <div class="page-nav">
    <div><a href="/<%= board.slug %>/">< Nazad k razdelu</a></div>
    <div><a href="/">Glavnaya</a></div>
    <div><a href="#" onclick="window.scrollTo(0,0);return false;">Naverh ^</a></div>
  </div>

</div>

<div class="footer">
  QWA Forum &copy; 2025 | /<%= board.slug %>/ | Thread #<%= thread.id %>
</div>

</body>
</html>