<!DOCTYPE html>
<html lang="ru"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= thread.subject || 'Тема #'+thread.id %> -- QWA</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .loading-overlay {
      display:none;position:fixed;top:0;left:0;width:100%;height:100%;
      background:rgba(0,0,0,0.85);z-index:9999;
      justify-content:center;align-items:center;flex-direction:column;
    }
    .loading-overlay.active{display:flex;}
    .spinner{width:50px;height:50px;border:4px solid #333;border-top:4px solid #fff;border-radius:50%;animation:spin 0.8s linear infinite;}
    @keyframes spin{0%{transform:rotate(0deg)}100%{transform:rotate(360deg)}}
    .loading-text{color:#fff;font-family:monospace;font-size:16px;margin-top:20px;}
    .loading-dots::after{content:'';animation:dots 1.5s infinite;}
    @keyframes dots{0%{content:''}25%{content:'.'}50%{content:'..'}75%{content:'...'}}
  </style>
  <script>
    function showLoading(t){
      var o=document.getElementById('loadingOverlay');
      o.querySelector('.loading-text').innerHTML=t+'<span class="loading-dots"></span>';
      o.classList.add('active');
    }
  </script>
</head><body>

<div class="loading-overlay" id="loadingOverlay">
  <div class="spinner"></div>
  <div class="loading-text"><span class="loading-dots"></span></div>
</div>

<div class="topbar">
  <div class="topbar-left">
    <a href="/">Главная</a>
    <% boards.forEach(b => { %>
      <a href="/<%= b.slug %>/"<% if(b.slug===board.slug){%> class="active"<%}%>>/<%= b.slug %>/</a>
    <% }); %>
  </div>
  <div class="topbar-right">
    <% if(currentUser){ %>
      <a href="/profile"><%= currentUser.username %></a>
      <%if(currentUser.role==='admin'){%><a href="/admin">[A]</a><%}%>
      <a href="/logout">Выйти</a>
    <% } else { %><a href="/login">Войти</a><% } %>
  </div>
</div>

<div class="breadcrumbs">
  <a href="/">QWA</a><span>></span>
  <a href="/<%= board.slug %>/">/<%= board.slug %>/</a><span>></span>
  <strong><%= thread.subject || 'Тема #'+thread.id %></strong>
</div>

<div class="container">
  <% if(currentUser && currentUser.role==='admin'){ %>
  <div class="admin-controls">
    <form method="POST" action="/admin/pin-thread" style="display:inline;">
      <input type="hidden" name="thread_id" value="<%= thread.id %>">
      <input type="hidden" name="board_slug" value="<%= board.slug %>">
      <input type="hidden" name="pin" value="<%= thread.is_pinned?0:1 %>">
      <button type="submit" class="admin-btn"><%= thread.is_pinned?'Открепить':'Закрепить' %></button>
    </form>
    <form method="POST" action="/admin/lock-thread" style="display:inline;">
      <input type="hidden" name="thread_id" value="<%= thread.id %>">
      <input type="hidden" name="board_slug" value="<%= board.slug %>">
      <input type="hidden" name="lock" value="<%= thread.is_locked?0:1 %>">
      <button type="submit" class="admin-btn"><%= thread.is_locked?'Открыть':'Закрыть' %></button>
    </form>
    <form method="POST" action="/admin/delete-thread" style="display:inline;" onsubmit="return confirm('Удалить тему?')">
      <input type="hidden" name="thread_id" value="<%= thread.id %>">
      <input type="hidden" name="board_slug" value="<%= board.slug %>">
      <button type="submit" class="admin-btn admin-btn-danger">Удалить тему</button>
    </form>
  </div>
  <% } %>

  <% if(currentUser && !thread.is_locked){ %>
  <div class="form-section">
    <div class="section-header">Ответить</div>
    <div class="form-body visible">
      <form action="/<%= board.slug %>/thread/<%= thread.id %>/reply" method="POST" enctype="multipart/form-data" onsubmit="showLoading('Отправляем ответ')">
        <div class="form-row"><div class="form-label">Сообщение</div>
          <div class="form-input"><textarea name="message" placeholder="Ваш ответ..." maxlength="10000"></textarea></div></div>
        <div class="form-row"><div class="form-label">Файл</div>
          <div class="form-input"><input type="file" name="file" accept=".jpg,.jpeg,.png,.gif,.webp,.mp4,.pdf,.zip,.rar,.txt">
            <div class="form-hint">Можно отправить только файл без текста</div></div></div>
        <div class="form-row"><div class="form-label"></div>
          <div class="form-input"><button type="submit" class="form-submit">Ответить</button></div></div>
      </form>
    </div>
  </div>
  <% } else if(thread.is_locked){ %>
    <div class="section-box"><div style="padding:12px;text-align:center;color:#888;">Тема закрыта. Ответы отключены.</div></div>
  <% } else { %>
    <div class="section-box"><div style="padding:12px;text-align:center;">
      <a href="/login?redirect=/<%= board.slug %>/thread/<%= thread.id %>">Войдите</a> чтобы отвечать.
    </div></div>
  <% } %>

  <!-- OP POST -->
  <div class="post op-post" id="p<%= thread.id %>">
    <div class="post-head">
      <div class="post-head-left">
        <% if(thread.subject){%><span class="post-subject"><%= thread.subject %></span><%}%>
        <span class="post-author"><a href="/user/<%= thread.author_name %>"><%= thread.author_name %></a></span>
        <span class="post-date"><%= formatDate(thread.created_at) %></span>
        <% if(thread.is_pinned){%><span class="pinned-tag">ЗАКРЕП</span><%}%>
        <% if(thread.is_locked){%><span class="locked-tag">ЗАКРЫТ</span><%}%>
      </div>
      <div class="post-num">No.<%= thread.id %></div>
    </div>
    <div class="post-body"><%- formatPost(thread.message) %></div>
  </div>

  <!-- REPLIES -->
  <% posts.forEach(p => { %>
  <div class="post reply-post" id="p<%= p.id %>">
    <div class="post-head">
      <div class="post-head-left">
        <span class="post-author"><a href="/user/<%= p.author_name %>"><%= p.author_name %></a></span>
        <span class="post-date"><%= formatDate(p.created_at) %></span>
      </div>
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="post-num"><a href="#p<%= p.id %>">No.<%= p.id %></a></div>
        <% if(currentUser && currentUser.role==='admin'){ %>
          <form method="POST" action="/admin/delete-post" style="display:inline;" onsubmit="return confirm('Удалить?')">
            <input type="hidden" name="post_id" value="<%= p.id %>">
            <input type="hidden" name="board_slug" value="<%= board.slug %>">
            <input type="hidden" name="thread_id" value="<%= thread.id %>">
            <button type="submit" class="admin-btn-sm">X</button>
          </form>
        <% } %>
      </div>
    </div>
    <% if(p.image_path){ %>
      <div class="post-file">
        <% if(isImg(p.image_path)){ %>
          <a href="/uploads/<%= p.image_path %>" target="_blank">
            <img src="/uploads/<%= p.image_path %>" class="post-image">
          </a>
        <% } else { %>
          <a href="/uploads/<%= p.image_path %>" class="file-link" target="_blank">
            Скачать файл: <%= p.image_path %>
          </a>
        <% } %>
      </div>
    <% } %>
    <% if(p.message){ %>
      <div class="post-body"><%- formatPost(p.message) %></div>
    <% } %>
  </div>
  <% }); %>

  <% if(!posts.length){ %>
    <div class="empty-state">Ответов пока нет. Будьте первым!</div>
  <% } %>

  <div class="reply-count-info">Ответов: <%= posts.length %></div>
  <div class="page-nav">
    <div><a href="/<%= board.slug %>/">< Назад</a></div>
    <div><a href="/">Главная</a></div>
    <div><a href="#" onclick="window.scrollTo(0,0);return false;">Наверх ^</a></div>
  </div>
</div>

<div class="footer">QWA Forum &copy; 2025</div>
</body></html>