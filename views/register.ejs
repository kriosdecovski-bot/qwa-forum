<!DOCTYPE html>
<html lang="ru"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Регистрация -- QWA</title>
  <link rel="stylesheet" href="/style.css">
</head><body>

<div class="topbar">
  <div class="topbar-left"><a href="/">QWA</a></div>
  <div class="topbar-right"><a href="/login">Войти</a></div>
</div>

<div class="container" style="max-width:450px;margin-top:40px;">
  <div class="section-box">
    <div class="section-header">Регистрация</div>
    <div style="padding:20px;">
      <% if (error) { %><div class="error-box"><%= error %></div><% } %>

      <% if (step === 'form') { %>
        <form method="POST" action="/register">
          <div class="form-row-stack"><label>Имя пользователя</label>
            <input type="text" name="username" required minlength="3" maxlength="20" placeholder="Буквы, цифры, _"></div>
          <div class="form-row-stack"><label>Email</label>
            <input type="email" name="email" required placeholder="Gmail, Mail.ru или Yandex">
            <div class="form-hint">Принимаются только Gmail, Mail.ru, Yandex</div></div>
          <div class="form-row-stack"><label>Пароль</label>
            <input type="password" name="password" required minlength="6" placeholder="Минимум 6 символов"></div>
          <div class="form-row-stack"><label>Повторите пароль</label>
            <input type="password" name="password2" required></div>
          <button type="submit" class="form-submit" style="width:100%;margin-top:10px;">Зарегистрироваться</button>
        </form>
        <div style="text-align:center;margin-top:15px;font-size:12px;">Уже есть аккаунт? <a href="/login">Войти</a></div>

      <% } else if (step === 'verify') { %>
        <p style="margin-bottom:15px;">Код отправлен на <strong><%= email %></strong></p>
        <form method="POST" action="/verify">
          <div class="form-row-stack"><label>Код подтверждения</label>
            <input type="text" name="code" required maxlength="6" placeholder="6 цифр" style="font-size:24px;text-align:center;letter-spacing:8px;"></div>
          <button type="submit" class="form-submit" style="width:100%;margin-top:10px;">Подтвердить</button>
        </form>
      <% } %>
    </div>
  </div>
</div>
</body></html>