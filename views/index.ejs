<!DOCTYPE html>
<html><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QWA Forum</title>
  <link rel="stylesheet" href="/style.css">
</head><body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/" class="active">Glavnaya</a>
    <% boards.forEach(function(b) { %>
      <a href="/<%= b.slug %>/">/<%= b.slug %>/</a>
    <% }); %>
  </div>
  <div class="topbar-right">
    <% if (currentUser) { %>
      <a href="/profile" style="color:#aaa;border:none;"><%= currentUser.username %></a>
      <% if(currentUser.role==='admin'){ %><a href="/admin" style="color:#fff;border:none;margin-left:5px;">[A]</a><% } %>
      <a href="/logout" style="color:#888;border:none;margin-left:8px;">vyyti</a>
    <% } else { %>
      <a href="/login" style="color:#aaa;border:none;">voyti</a>
      <a href="/register" style="color:#aaa;border:none;margin-left:8px;">registraciya</a>
    <% } %>
  </div>
</div>

<div class="header">
  <h1>QWA</h1>
  <div class="tagline">forum dlya lyudey -- est. 2025</div>
</div>

<div class="container">

  <div class="stats-bar">
    <div class="stat-item">Tem: <span class="stat-num"><%= stats.total_threads %></span></div>
    <div class="stat-item">Postov: <span class="stat-num"><%= stats.total_posts %></span></div>
    <div class="stat-item">Polzovateley: <span class="stat-num"><%= stats.total_users %></span></div>
  </div>

  <div class="section-box">
    <div class="section-header">Razdely foruma</div>
    <table class="forum-table">
      <thead>
        <tr>
          <th class="col-board">Razdel</th>
          <th class="col-stats">Temy</th>
          <th class="col-stats">Posty</th>
        </tr>
      </thead>
      <tbody>
        <% boards.forEach(function(b) { %>
        <tr>
          <td>
            <div class="board-name">
              <a href="/<%= b.slug %>/"><%= b.name %></a>
              <span class="board-slug">/<%= b.slug %>/</span>
              <% if(b.admin_only){ %><span class="locked-tag">ADMINS</span><% } %>
            </div>
            <div class="board-desc"><%= b.description %></div>
          </td>
          <td class="col-stats"><%= b.threadCount %></td>
          <td class="col-stats"><%= b.postCount %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% if (!currentUser) { %>
  <div class="section-box">
    <div style="padding:15px;text-align:center;font-size:13px;">
      <a href="/register" style="font-weight:bold;">Zaregistriruytes</a> chtoby sozdavat temy i otvechat.
    </div>
  </div>
  <% } %>

</div>

<div class="footer">QWA Forum &copy; 2025</div>
</body></html>