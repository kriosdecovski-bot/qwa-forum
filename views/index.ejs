<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QWA Forum</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/" class="active">Glavnaya</a>
    <% boards.forEach(function(b) { %>
      <a href="/<%= b.slug %>/">/<%= b.slug %>/</a>
    <% }); %>
  </div>
  <div class="topbar-right">QWA Forum</div>
</div>

<div class="header">
  <h1>QWA</h1>
  <div class="tagline">anonymous text forum -- est. 2025</div>
</div>

<div class="container">

  <div class="stats-bar">
    <div class="stat-item">
      Vsego tem: <span class="stat-num"><%= stats.total_threads %></span>
    </div>
    <div class="stat-item">
      Vsego postov: <span class="stat-num"><%= stats.total_posts %></span>
    </div>
    <div class="stat-item">
      Razdelov: <span class="stat-num"><%= boards.length %></span>
    </div>
  </div>

  <div class="section-box">
    <div class="section-header">Razdely foruma</div>
    <table class="forum-table">
      <thead>
        <tr>
          <th class="col-board">Razdel</th>
          <th class="col-stats">Temy</th>
          <th class="col-stats">Posty</th>
        </tr>
      </thead>
      <tbody>
        <% boards.forEach(function(b) { %>
        <tr>
          <td class="col-board">
            <div class="board-name">
              <a href="/<%= b.slug %>/"><%= b.name %></a>
              <span class="board-slug">/<%= b.slug %>/</span>
            </div>
            <div class="board-desc"><%= b.description %></div>
          </td>
          <td class="col-stats"><%= b.threadCount %></td>
          <td class="col-stats"><%= b.postCount %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="section-box">
    <div class="section-header-light">O forume</div>
    <div style="padding:12px 15px; font-size:12px; color:#666; line-height:1.8;">
      QWA -- anonimnyy tekstovyy forum. Registraciya ne nuzhna.<br>
      Pishi kak Anonymous ili ispolzuy tripcode: Imya#sekret.<br>
      Greentext: nachinayte stroku s &gt; dlya citatirovaniya.<br>
      Ssylki na posty: &gt;&gt;123<br>
      Sage: vvedite "sage" v pole imeni chtoby ne podnimat temu.
    </div>
  </div>

</div>

<div class="footer">
  QWA Forum &copy; 2025 | No registration. No emojis. No bullshit.
</div>

</body>
</html>