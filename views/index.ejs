<!DOCTYPE html>
<html lang="ru"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QWA Forum</title>
  <link rel="stylesheet" href="/style.css">
</head><body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/" class="topbar-logo">QWA</a>
  </div>
  <div class="topbar-right">
    <% if (currentUser) { %>
      <% if(['owner','coowner'].includes(currentUser.role)){ %>
        <a href="/owner" class="top-btn top-btn-red">Owner Panel</a>
      <% } %>
      <% if(['owner','coowner','admin'].includes(currentUser.role)){ %>
        <a href="/admin" class="top-btn top-btn-dark">Админка</a>
      <% } %>
      <a href="/messages" class="top-btn top-btn-dark">Сообщения<% if(typeof unread!=='undefined' && unread>0){ %> <span class="msg-badge"><%= unread %></span><% } %></a>
      <a href="/profile" class="top-btn top-btn-outline"><%= currentUser.username %></a>
      <a href="/logout" class="top-btn top-btn-ghost">Выйти</a>
    <% } else { %>
      <a href="/login" class="top-btn top-btn-dark">Войти</a>
      <a href="/register" class="top-btn top-btn-outline">Регистрация</a>
    <% } %>
  </div>
</div>

<div class="header">
  <h1>QWA</h1>
  <div class="tagline">Форум для людей</div>
</div>

<div class="container">

  <form action="/search" method="GET" class="search-bar">
    <input type="text" name="q" placeholder="Поиск по темам..." maxlength="100">
    <button type="submit">Найти</button>
  </form>

  <div class="stats-bar">
    <div class="stat-item">Тем: <span class="stat-num"><%= stats.total_threads %></span></div>
    <div class="stat-item">Постов: <span class="stat-num"><%= stats.total_posts %></span></div>
    <div class="stat-item">Пользователей: <span class="stat-num"><%= stats.total_users %></span></div>
  </div>

  <!-- Кнопки разделов -->
  <div class="board-buttons">
    <% boards.forEach(b => { %>
      <a href="/<%= b.slug %>/" class="board-btn">
        <div class="board-btn-name"><%= b.name %></div>
        <div class="board-btn-desc"><%= b.description %></div>
        <div class="board-btn-stats"><%= b.tc %> тем / <%= b.pc %> постов</div>
        <% if(b.admin_only){ %><span class="board-btn-badge">Админ</span><% } %>
      </a>
    <% }); %>
  </div>

  <div class="two-columns">
    <div class="main-col">
      <% if (!currentUser) { %>
      <div class="section-box">
        <div class="section-header">Присоединяйтесь</div>
        <div style="padding:20px;text-align:center;font-size:14px;line-height:1.8;">
          <a href="/register" class="big-btn">Зарегистрироваться</a>
          <p style="margin-top:10px;color:#888;">Уже есть аккаунт? <a href="/login">Войти</a></p>
        </div>
      </div>
      <% } %>
    </div>

    <div class="side-col">
      <div class="section-box">
        <div class="section-header">Последние сообщения</div>
        <div class="recent-posts">
          <% if(recent && recent.length) { recent.forEach(p => { %>
            <div class="recent-item">
              <div class="recent-author"><strong><%= p.author_name %></strong></div>
              <div class="recent-text"><%= (p.message||'').substring(0,80) %><%= (p.message||'').length>80?'...':'' %></div>
              <div class="recent-meta">
                в <a href="/<%= p.board_slug %>/thread/<%= p.thread_id %>#p<%= p.id %>"><%= p.thread_subject || 'теме' %></a>
                -- <%= formatDate(p.created_at) %>
              </div>
            </div>
          <% }); } else { %>
            <div class="recent-item" style="color:#999;">Пока ничего нет</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="footer">QWA Forum &copy; 2025</div>
</body></html>