<!DOCTYPE html>
<html lang="ru"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= user.username %> -- QWA</title>
  <link rel="stylesheet" href="/style.css">
</head><body>

<div class="topbar">
  <div class="topbar-left"><a href="/" class="topbar-logo">QWA</a></div>
  <div class="topbar-right">
    <% if(currentUser){ %>
      <a href="/messages" class="top-btn top-btn-dark">Сообщения</a>
      <a href="/profile" class="top-btn top-btn-outline"><%= currentUser.username %></a>
      <a href="/logout" class="top-btn top-btn-ghost">Выйти</a>
    <% } else { %>
      <a href="/login" class="top-btn top-btn-dark">Войти</a>
    <% } %>
  </div>
</div>

<div class="container" style="max-width:550px;margin-top:30px;">
  <div class="section-box">
    <div class="section-header">Профиль</div>
    <div style="padding:25px;">

      <!-- Аватарка и имя -->
      <div style="text-align:center;margin-bottom:20px;">
        <% if(user.avatar){ %>
          <img src="/uploads/<%= user.avatar %>" class="user-avatar-big">
        <% } else { %>
          <div class="avatar-default-big"><%= user.username.charAt(0).toUpperCase() %></div>
        <% } %>
        <div style="margin-top:8px;">
          <strong style="font-size:18px;"><%= user.username %></strong>
          <%- getRolePrefix(user.role) %>
        </div>
      </div>

      <div class="profile-info">
        <div class="profile-row">
          <span class="profile-label">Сообщений</span>
          <span><%= user.post_count || 0 %></span>
        </div>
        <div class="profile-row">
          <span class="profile-label">Регистрация</span>
          <span><%= formatDate(user.created_at) %></span>
        </div>
        <% if(user.about){ %>
        <div class="profile-row">
          <span class="profile-label">О себе</span>
          <span><%= user.about %></span>
        </div>
        <% } %>
      </div>

      <!-- Кнопка написать в ЛС -->
      <% if(currentUser && currentUser.id !== user.id){ %>
        <div style="margin-top:20px;text-align:center;">
          <a href="/messages/chat/<%= user.username %>" class="big-btn">Написать сообщение</a>
        </div>
      <% } %>

    </div>
  </div>
</div>

<div class="footer">QWA Forum</div>
</body></html>