<!DOCTYPE html>
<html lang="ru"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Чат с <%= other.username %> -- QWA</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .chat-box { max-height:500px; overflow-y:auto; padding:15px; background:#fafafa; border:1px solid #ddd; margin-bottom:15px; }
    .chat-msg { margin-bottom:12px; padding:8px 12px; max-width:80%; }
    .chat-msg.mine { background:#e8e8e8; border-left:3px solid #333; margin-left:auto; }
    .chat-msg.theirs { background:#fff; border-left:3px solid #999; }
    .chat-author { font-weight:bold; font-size:12px; }
    .chat-text { font-size:13px; margin-top:4px; }
    .chat-time { font-size:10px; color:#999; margin-top:4px; }
  </style>
</head><body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/">QWA</a>
    <a href="/messages">ЛС</a>
  </div>
  <div class="topbar-right">
    <a href="/profile"><%= currentUser.username %></a>
    <a href="/logout">Выйти</a>
  </div>
</div>

<div class="breadcrumbs">
  <a href="/">QWA</a><span>></span>
  <a href="/messages">Сообщения</a><span>></span>
  <strong><%= other.username %></strong>
</div>

<div class="container" style="max-width:600px;">
  <div class="section-box">
    <div class="section-header">Чат с <%= other.username %></div>
    <div class="chat-box" id="chatBox">
      <% if(!msgs.length) { %>
        <div style="text-align:center;color:#999;padding:20px;">Сообщений пока нет</div>
      <% } %>
      <% msgs.forEach(m => { %>
        <div class="chat-msg <%= m.from_id === currentUser.id ? 'mine' : 'theirs' %>">
          <div class="chat-author"><%= m.from_name %></div>
          <div class="chat-text"><%= m.message %></div>
          <div class="chat-time"><%= formatDate(m.created_at) %></div>
        </div>
      <% }); %>
    </div>

    <form method="POST" action="/messages/send/<%= other.username %>" style="display:flex;gap:8px;padding:0 15px 15px;">
      <textarea name="message" placeholder="Сообщение..." required maxlength="2000"
        style="flex:1;padding:8px;border:1px solid #ccc;font-size:13px;font-family:inherit;height:60px;resize:none;"></textarea>
      <button type="submit" class="form-submit" style="align-self:flex-end;">Отправить</button>
    </form>
  </div>
</div>

<script>var cb=document.getElementById('chatBox');cb.scrollTop=cb.scrollHeight;</script>

<div class="footer">QWA Forum</div>
</body></html>