<!DOCTYPE html>
<html lang="ru"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Админ-панель -- QWA</title>
  <link rel="stylesheet" href="/style.css">
</head><body>

<div class="topbar">
  <div class="topbar-left"><a href="/">QWA</a> <a href="/admin" class="active">Админ</a></div>
  <div class="topbar-right"><span><%= currentUser.username %> [АДМИН]</span><a href="/logout">Выйти</a></div>
</div>

<div class="container">
  <div class="stats-bar">
    <div class="stat-item">Пользователей: <span class="stat-num"><%= stats.total_users %></span></div>
    <div class="stat-item">Тем: <span class="stat-num"><%= stats.total_threads %></span></div>
    <div class="stat-item">Постов: <span class="stat-num"><%= stats.total_posts %></span></div>
  </div>

  <div class="section-box">
    <div class="section-header">Пользователи</div>
    <table class="forum-table">
      <thead><tr><th>ID</th><th>Имя</th><th>Email</th><th>Роль</th><th>Постов</th><th>Действия</th></tr></thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr>
          <td><%= u.id %></td>
          <td><strong><a href="/user/<%= u.username %>"><%= u.username %></a></strong></td>
          <td style="font-size:11px;color:#888;"><%= u.email %></td>
          <td><% if(u.role==='admin'){ %><span class="pinned-tag">АДМИН</span>
            <% } else if(u.role==='mod'){ %><span class="locked-tag">МОД</span>
            <% } else { %>user<% } %></td>
          <td><%= u.post_count || 0 %></td>
          <td><form method="POST" action="/admin/set-role" style="display:inline;">
            <input type="hidden" name="user_id" value="<%= u.id %>">
            <select name="role" style="font-size:11px;padding:2px;">
              <option value="user" <%=u.role==='user'?'selected':''%>>user</option>
              <option value="mod" <%=u.role==='mod'?'selected':''%>>mod</option>
              <option value="admin" <%=u.role==='admin'?'selected':''%>>admin</option>
            </select>
            <button type="submit" style="font-size:11px;padding:2px 6px;cursor:pointer;">OK</button>
          </form></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="section-box">
    <div class="section-header">Разделы</div>
    <table class="forum-table">
      <thead><tr><th>Раздел</th><th>Название</th><th>Только админы</th></tr></thead>
      <tbody>
        <% boards.forEach(b => { %>
        <tr>
          <td><a href="/<%= b.slug %>/">/<%= b.slug %>/</a></td>
          <td><%= b.name %></td>
          <td><%= b.admin_only ? 'Да' : 'Нет' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<div class="footer">QWA Forum &copy; 2025 | Админ-панель</div>
</body></html>