<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>/<%= board.slug %>/ -- <%= board.name %> -- QWA</title>
  <link rel="stylesheet" href="/style.css">
  <script>
    function toggleForm() {
      var f = document.getElementById('post-form-body');
      f.classList.toggle('visible');
    }
  </script>
</head>
<body>

<div class="topbar">
  <div class="topbar-left">
    <a href="/">Glavnaya</a>
    <% boards.forEach(function(b) { %>
      <a href="/<%= b.slug %>/"<% if(b.slug===board.slug){ %> class="active"<% } %>>/<%= b.slug %>/</a>
    <% }); %>
  </div>
  <div class="topbar-right">QWA Forum</div>
</div>

<div class="breadcrumbs">
  <a href="/">QWA</a>
  <span>></span>
  <strong>/<%= board.slug %>/ -- <%= board.name %></strong>
</div>

<div class="container">

  <!-- POST FORM -->
  <div class="form-section">
    <button class="form-toggle" onclick="toggleForm()">+ Sozdat novuyu temu</button>
    <div class="form-body" id="post-form-body">
      <form action="/<%= board.slug %>/post" method="POST">
        <div class="form-row">
          <div class="form-label">Imya</div>
          <div class="form-input">
            <input type="text" name="name" placeholder="Anonymous" maxlength="50">
            <div class="form-hint">Ostavte pustym dlya anonimnogo posta. Tripcode: Imya#sekret</div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-label">Tema</div>
          <div class="form-input">
            <input type="text" name="subject" placeholder="Zagolovok temy" maxlength="100">
          </div>
        </div>
        <div class="form-row">
          <div class="form-label">Soobshenie</div>
          <div class="form-input">
            <textarea name="message" placeholder="Tekst soobsheniya..." maxlength="5000" required></textarea>
            <div class="form-hint">&gt;greentext &gt;&gt;123 ssylka na post. Maks 5000 simvolov.</div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-label"></div>
          <div class="form-input">
            <button type="submit" class="form-submit">Otpravit</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- THREAD LIST -->
  <div class="section-box">
    <div class="section-header">/<%= board.slug %>/ -- <%= board.name %></div>

    <% if (threads.length === 0) { %>
      <div class="empty-state">
        Tem poka net. Budte pervym!
      </div>
    <% } else { %>
      <table class="thread-table">
        <thead>
          <tr>
            <th style="width:50%">Tema</th>
            <th class="col-author">Avtor</th>
            <th class="col-replies">Otvety</th>
            <th class="col-date">Posledny post</th>
          </tr>
        </thead>
        <tbody>
          <% threads.forEach(function(t) { %>
          <tr>
            <td>
              <div class="thread-subject">
                <% if (t.is_pinned) { %><span class="pinned-tag">PIN</span><% } %>
                <% if (t.is_locked) { %><span class="locked-tag">LOCK</span><% } %>
                <a href="/<%= board.slug %>/thread/<%= t.id %>">
                  <%= t.subject || 'No subject #' + t.id %>
                </a>
              </div>
              <div class="thread-preview">
                <%= t.message.substring(0, 120) %><%= t.message.length > 120 ? '...' : '' %>
              </div>
            </td>
            <td class="col-author">
              <strong><%= t.author %></strong>
              <div class="thread-meta"><%= formatDate(t.created_at) %></div>
            </td>
            <td class="col-replies">
              <%= t.reply_count_live %>
            </td>
            <td class="col-date">
              <%= formatDate(t.bumped_at) %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </div>

  <div class="page-nav">
    <div><a href="/">< Glavnaya</a></div>
    <div>
      Vsego tem: <strong><%= threads.length %></strong>
    </div>
    <div><a href="#" onclick="window.scrollTo(0,0);return false;">Naverh ^</a></div>
  </div>

</div>

<div class="footer">
  QWA Forum &copy; 2025 | /<%= board.slug %>/ -- <%= board.name %>
</div>

</body>
</html>